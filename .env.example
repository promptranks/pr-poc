# PromptRanks PoC - Environment Configuration
# Copy this file to .env and fill in your values

# === Required ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Database ===
POSTGRES_USER=promptranks
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=promptranks
DATABASE_URL=postgresql://promptranks:change-me-in-production@postgres:5432/promptranks

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Frontend ===
VITE_API_URL=http://localhost:8000

# === LLM ===
LLM_EXECUTOR_MODEL=claude-sonnet-4-6
LLM_JUDGE_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# === Assessment ===
QUICK_ASSESSMENT_TIME_LIMIT=900
FULL_KBA_TIME_LIMIT=900
FULL_PPA_TIME_LIMIT=1800
